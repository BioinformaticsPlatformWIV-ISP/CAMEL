<tool id="checkm" name="CheckM - Lineage workflow" version="0.1">
    <description>Quality assessment of assembled microbial genomes</description>
    <command>
    <![CDATA[
        $__tool_directory__/run_checkm.sh
        #for $i in $input_fasta:
            --fasta $i "$i.name"
        #end for
        --output-html "$output"
        --output-dir "$output.files_path"
    ]]>
    </command>

    <inputs>
        <param name="input_fasta" type="data" multiple="true" format="fasta" label="Input contigs (FASTA)" />
    </inputs>
    <outputs>
        <data name="output" format="tabular" label="CheckM on ${on_string}"/>
    </outputs>
    <stdio>
        <exit_code range="1:" level="fatal" />
    </stdio>

    <help>
    <![CDATA[
    More information can be found here: https://github.com/Ecogenomics/CheckM
    ]]>
    </help>
</tool>