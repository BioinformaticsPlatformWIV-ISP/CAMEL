to use snakemake:
cd /scratch/todel/GATK_Camel_test/pipeline
then:

if using snakemake without python main script:

. /home/todel/PycharmProjects/camel_3.0/camel_3_env/bin/activate
export PYTHONPATH=/home/todel/PycharmProjects/camel_3.0
snakemake --snakefile /home/todel/PycharmProjects/camel_3.0/scripts/todel_tests/test.snakefile --configfile /home/todel/PycharmProjects/camel_3.0/scripts/todel_tests/config.yaml --cores 16


if using python main script:

. /home/todel/PycharmProjects/camel_3.0/camel_3_env/bin/activate

export PYTHONPATH=/home/todel/PycharmProjects/camel_3.0

python /home/todel/PycharmProjects/camel_3.0/scripts/todel_tests/run_test_pipeline.py

python /home/todel/PycharmProjects/camel_3.0/scripts/todel_tests/run_test_pipeline.py -W /scratch/todel/GATK_Camel_test/pipeline/working/ -R broad_b37_human_Genome_1K_v37 -S broad_b37_snps_high_confidence -I broad_b37_indels_gold_standard -PE /scratch/todel/GATK_Camel_test/pipeline/inputs_and_files/input1.fq /scratch/todel/GATK_Camel_test/pipeline/inputs_and_files/input2.fq

python /home/todel/PycharmProjects/camel_3.0/scripts/todel_tests/run_test_pipeline.py -W /scratch/todel/GATK_Camel_test/pipeline/working/ -R broad_b37_human_Genome_1K_v37 -S broad_b37_snps_high_confidence -I broad_b37_indels_gold_standard -PE /scratch/todel/GATK_Camel_test/pipeline/inputs_and_files/input1.fq /scratch/todel/GATK_Camel_test/pipeline/inputs_and_files/input2.fq --vcf_output vcf_output_test.vcf --tab_output txt_output_test.txt --bam_output bam_output.bam --covar_output covar_output.pdf


python /home/todel/PycharmProjects/camel_3.0/scripts/gatksomaticvariantcalling/run_gatk_somatic_pipeline.py -W /scratch/todel/GATK_Camel_test/pipeline/working/ -R broad_b37_human_Genome_1K_v37 -S broad_b37_snps_high_confidence -I broad_b37_indels_gold_standard -PE /scratch/todel/GATK_Camel_test/pipeline/inputs_and_files/input1.fq /scratch/todel/GATK_Camel_test/pipeline/inputs_and_files/input2.fq --vcf_output vcf_output_test.vcf --tab_output txt_output_test.txt --bam_output bam_output.bam --covar_output covar_output.pdf
